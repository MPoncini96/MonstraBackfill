# Copy to .env for local runs:  cp .env.example .env  (optional)

# Required in production: same value must be set on Vercel as MONSTRA_PREVIEW_SECRET
MONSTRA_PREVIEW_SECRET=replace-with-a-long-random-string

# Optional: allow browser calls from your Next app (comma-separated origins)
# MONSTRA_PREVIEW_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
